[flake8]
max-line-length = 120

# Style choices intentionally used throughout this codebase:
#   E221 — column-aligned assignments (e.g.  key   = value)
#   E402 — sys.path.insert before project imports (required pattern)
#   E501 — long lines in dense data structures and strategy logic
#   E701/E702 — single-line if/semicolons in compact backtest code
#   E129 — visual indentation style
#   W291/W293/W391 — trailing / blank-line whitespace (cosmetic)
#   W503 — line break before binary operator (PEP 8 preference)
extend-ignore =
    E129,E201,E202,
    E221,
    E225,E226,E228,E231,E241,E242,
    E261,E262,E265,E266,E271,E272,
    E301,E302,E303,E304,E305,E306,
    E402,E501,
    E701,E702,
    W291,W293,W391,W503

exclude =
    __pycache__,
    .venv,
    venv,
    .git

per-file-ignores =
    # F401 unused imports: intentional SDK re-exports or conditional usage
    core/alpaca_client.py:        F401
    core/order_executor.py:       F401
    core/risk_manager.py:         F401
    scheduler/run_backtest.py:    F401
    strategies/momentum.py:       F401
    strategies/range_breakout.py: F401
    strategies/rsi_reversion.py:  F401
    tests/test_v4_improvements.py: F401
    tracking/performance.py:      F401
    tracking/trade_log.py:        F401

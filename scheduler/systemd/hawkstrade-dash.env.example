# HawksTrade Dashboard environment file.
#
# Install this at /etc/hawkstrade-dash/env (mode 640, owner root:hawkstrade-dash).
# systemd's EnvironmentFile= directive in hawkstrade-dashboard.service reads from there.
#
# DO NOT commit this file with real values. The repo ships only this .example.

# ── Auth mode ────────────────────────────────────────────────────────────────
# local       = bypass auth (Phase 1; ONLY safe behind SSH tunnel on 127.0.0.1)
# cloudflare  = verify Cf-Access-Jwt-Assertion on every request (Phase 2 default)
DASHBOARD_AUTH_MODE=cloudflare

# ── Cloudflare Access settings (required when DASHBOARD_AUTH_MODE=cloudflare) ─
# Team domain from Cloudflare Zero Trust (looks like: yourteam.cloudflareaccess.com)
CF_ACCESS_TEAM_DOMAIN=REPLACE_ME.cloudflareaccess.com
# Application Audience (AUD) tag — find it in Zero Trust → Access → Applications → Overview
CF_ACCESS_AUD=REPLACE_ME_AUD_TAG
# Defense-in-depth: comma-separated allowlist the app enforces on top of Cloudflare's policy.
DASHBOARD_ALLOWED_EMAILS=you@example.com

# ── Read-only Alpaca API key ─────────────────────────────────────────────────
# DEDICATED key pair, separate from the bot's trading keys. Rotate every 90 days.
# Use the same endpoint (paper/live) that the bot is running in — otherwise live P&L will be wrong.
ALPACA_PAPER_API_KEY=REPLACE_ME_READONLY_KEY
ALPACA_PAPER_SECRET_KEY=REPLACE_ME_READONLY_SECRET
# Uncomment the live keys ONLY if the bot is running in live mode. Even then, these
# should be a separate read-only key pair, never the same keys used for trading.
#ALPACA_LIVE_API_KEY=REPLACE_ME_READONLY_LIVE_KEY
#ALPACA_LIVE_SECRET_KEY=REPLACE_ME_READONLY_LIVE_SECRET

# ── Bot config discovery ─────────────────────────────────────────────────────
# The dashboard reads config/config.yaml for mode, risk limits, etc. No extras needed.
# HAWKSTRADE_REQUIRE_SHM MUST remain unset — the dashboard uses its own keys,
# not /dev/shm/.hawkstrade.env.

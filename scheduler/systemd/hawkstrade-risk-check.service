[Unit]
Description=HawksTrade risk check
Documentation=file:/home/ec2-user/HawksTrade/scheduler/systemd/README.md
Wants=network-online.target
After=network-online.target hawkstrade-secrets.service
Requires=hawkstrade-secrets.service

[Service]
Type=oneshot
User=ec2-user
Group=ec2-user
WorkingDirectory=/home/ec2-user/HawksTrade
EnvironmentFile=/etc/hawkstrade/hawkstrade.env
Environment=HAWKSTRADE_REQUIRE_SHM=1
ExecStart=/home/ec2-user/HawksTrade/scripts/run_hawkstrade_job.sh scheduler/run_risk_check.py
Restart=no
TimeoutStartSec=30min
StandardOutput=journal
StandardError=journal

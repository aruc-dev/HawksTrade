# ============================================================
# HawksTrade - Alpaca API Keys
# ============================================================
# Copy this file to config/.env and fill in your actual keys.
# A root .env file is also supported and takes precedence over config/.env.
# NEVER commit config/.env or .env to version control.

# --- PAPER TRADING (Alpaca Paper) ---
ALPACA_PAPER_API_KEY=your_paper_api_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key_here

# --- LIVE TRADING (Alpaca Live) ---
ALPACA_LIVE_API_KEY=your_live_api_key_here
ALPACA_LIVE_SECRET_KEY=your_live_secret_key_here

# --- Optional: News/Sentiment API ---
# NEWS_API_KEY=your_news_api_key_here
